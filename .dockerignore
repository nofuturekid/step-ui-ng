# Keep the build context small.
# NOTE: dist/ is intentionally NOT excluded — Dockerfile.release copies the
# prebuilt binary from dist/stepui_linux_${TARGETARCH}.
.git
.github
.claude
bin/
/stepui
data/
*.db
*.db-*
secret.key
# Generated by `go tool templ generate` inside the build stage (2-stage
# Dockerfile regenerates them; Dockerfile.release does not need them).
*_templ.go
# Docs/specs not needed to build the image.
docs/
spec/
*.md
